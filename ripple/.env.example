# Lemonville configuration — EVERYTHING here is OPTIONAL.
# With no .env at all, the game runs fully offline (mock delegate + heuristic
# examiner, in-memory storage). Copy this file to `.env` and fill in only what
# you want. NEVER commit your real .env (it is gitignored).

# ─────────────────────────────────────────────────────────────────────────────
# LLM — bring your own key (optional; only needed for live AI agents)
# Works with ANY OpenAI-compatible endpoint: Nebius, OpenAI, Together, Groq,
# Fireworks, OpenRouter, a local Ollama/vLLM server, etc. Just set the base URL,
# your key, and two model names (a small/fast one for the student's delegate and
# a larger one for the examiner). Leave blank to use the built-in offline agents.
LLM_API_KEY=
LLM_BASE_URL=https://api.studio.nebius.com/v1/
LLM_MODEL_SMALL=meta-llama/Llama-3.1-8B-Instruct
LLM_MODEL_LARGE=meta-llama/Llama-3.3-70B-Instruct
#
# Examples for other providers (uncomment ONE set):
#   OpenAI:   LLM_BASE_URL=https://api.openai.com/v1/   LLM_MODEL_SMALL=gpt-4o-mini   LLM_MODEL_LARGE=gpt-4o
#   Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1/
#   Ollama:   LLM_BASE_URL=http://localhost:11434/v1/   LLM_API_KEY=ollama   LLM_MODEL_SMALL=llama3.1   LLM_MODEL_LARGE=llama3.1:70b

# Force the offline mock/heuristic agents even when a key is present:
# RIPPLE_MOCK=1

# ─────────────────────────────────────────────────────────────────────────────
# Persistence (optional) — leave blank to keep everything in memory.
# Butterbase-compatible storage for world snapshots / decision logs / skill models.
# BUTTERBASE_APP_ID=
# BUTTERBASE_API_KEY=
# BUTTERBASE_URL=https://api.butterbase.ai

# EverOS / EverMind student skill-memory (optional; enables adaptive re-casting
# across sessions). Leave blank to disable.
# EVEROS_API_KEY=
# EVEROS_URL=https://api.evermind.ai

# ─────────────────────────────────────────────────────────────────────────────
# Server (optional)
# PORT=3001
# PUBLIC_URL=            # if hosting behind a domain/tunnel, the join QR uses this
