# Copy to .env (never commit .env). Node scripts load it via process.loadEnvFile().

# Claude API — delegate + examiner agents (task 0.4)
ANTHROPIC_API_KEY=sk-ant-...

# Butterbase (storage; wrapper falls back to in-memory when unset)
# App "ripple" already provisioned with tables world_state / decision_logs /
# skill_models / leaderboard (snake_case columns; wrapper maps from contracts).
BUTTERBASE_APP_ID=app_bofh7mbux05x
BUTTERBASE_API_KEY=bb_sk_...  # get from teammate, never commit
# BUTTERBASE_URL=https://api.butterbase.ai

# EverOS / EverMind Cloud (student memory layer; wrapper falls back to in-memory when unset)
# Var name per docs.evermind.ai ("or set EVEROS_API_KEY env var")
EVEROS_API_KEY=
# EVEROS_URL=https://api.evermind.ai

# Set to 1 to force mock/heuristic agents even when a key is present
# RIPPLE_MOCK=1
